# Copy this file to compose/.env and replace both placeholder passwords.
# compose/.env is ignored by git.

TZ=Europe/Paris
LIGHTHOUSE_LAN_BIND=0.0.0.0
PIHOLE_WEB_PORT=8080
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093

PIHOLE_UPSTREAMS=9.9.9.9;149.112.112.112
PIHOLE_ADMIN_PASSWORD=replace-with-a-long-random-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-different-long-random-password

# Hosted ntfy.sh values. Keep the topic private and use an access token with
# publish permission for that topic.
NTFY_TOPIC=replace-with-a-private-topic
NTFY_TOKEN=tk_replace-with-a-publish-token
